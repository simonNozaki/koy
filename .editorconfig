[*.{kt,kts}]
# Wrap function signatures only when they exceed max_line_length,
# not based on parameter count alone
ktlint_function_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = unset

# Do not force wrapping of the right-hand side of assignments onto a new line
ktlint_standard_multiline-expression-wrapping = disabled
